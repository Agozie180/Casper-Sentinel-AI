{
  "name": "@casper-sentinel/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src --ext .ts",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@casper-sentinel/config": "workspace:*",
    "@casper-sentinel/casper": "workspace:*"
  },
  "devDependencies": {
    "tsx": "latest",
    "vitest": "latest"
  }
}
